# ─────────────────────────────────────────────────────────────────
# Environment & secrets
# ─────────────────────────────────────────────────────────────────
.env
.env.*.local
.env.local
*.pem
*.key

# ─────────────────────────────────────────────────────────────────
# Data (corpus + caches — never commit)
# Exception: data/raw/_index.csv is committed so the repo records
# which filings have been fetched (the .htm files themselves stay out).
# ─────────────────────────────────────────────────────────────────
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/raw/_index.csv
!data/processed/.gitkeep
*.pdf
*.parquet

# ─────────────────────────────────────────────────────────────────
# Python (api/)
# ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
sdist/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# DELIBERATELY NOT IGNORING: lib/, lib64/, parts/, var/.
# Those are part of the legacy Python egg-install template, but this
# repo's frontend lives under web/lib/. The Python venv is at .venv/
# (see uv setup) and is already excluded.

# uv lockfile is committed; cache is not
.uv/

# Sentence-transformers / Hugging Face model cache (large)
.cache/
huggingface/

# ─────────────────────────────────────────────────────────────────
# Node (web/)
# ─────────────────────────────────────────────────────────────────
node_modules/
.next/
out/
build/
.vercel/
.turbo/
*.tsbuildinfo
next-env.d.ts

# Package manager artifacts
.pnpm-store/
.yarn/
.npm/

# ─────────────────────────────────────────────────────────────────
# Editors / OS
# ─────────────────────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ─────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─────────────────────────────────────────────────────────────────
# Postgres data volume (if mounted locally)
# ─────────────────────────────────────────────────────────────────
.postgres-data/
pgdata/

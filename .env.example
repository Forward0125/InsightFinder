# ─────────────────────────────────────────────────────────────────
# InsightFinder — environment template
# Copy to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────
# Local dev (matches docker-compose.yml). For prod use Neon.
DATABASE_URL=postgresql://insight:insight@localhost:5432/insightfinder

# ─── LLM / Embeddings ────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Models (override here if you want to swap)
EMBEDDING_MODEL=text-embedding-3-small
RERANKER_MODEL=BAAI/bge-reranker-base
GENERATOR_MODEL=claude-sonnet-4-6

# ─── Backend ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# Cost guards on public ingestion
MAX_UPLOAD_MB=5
MAX_PAGES_PER_PDF=50
RATE_LIMIT_PER_IP_PER_HOUR=20

# ─── Frontend ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Observability (optional) ────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO

# ─── SEC EDGAR ───────────────────────────────────────────────────
# SEC requires User-Agent in format: "Name email@domain.com".
# Override the default in scripts/sec_fetch.py for production use.
SEC_USER_AGENT=InsightFinder Demo demo@insightfinder.dev
